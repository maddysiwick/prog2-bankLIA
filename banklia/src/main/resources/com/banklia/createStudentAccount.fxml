<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>
<?import java.lang.Integer?>
<?import javafx.collections.FXCollections?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banklia.CreateAccountController">
    <children>
        <Label text="Student Client Graduation Date" />
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <ComboBox fx:id="yearBox" promptText="year">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <Integer fx:value="2026"/>
                            <Integer fx:value="2027"/>
                            <Integer fx:value="2028"/>
                            <Integer fx:value="2029"/>
                            <Integer fx:value="2030"/>
                            <Integer fx:value="2032"/>
                            <Integer fx:value="2033"/>
                            <Integer fx:value="2034"/>
                            <Integer fx:value="2035"/>
                            <Integer fx:value="2036"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="monthBox" promptText="month">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <Integer fx:value="1">
                            <Integer fx:value="2">
                            <Integer fx:value="3">
                            <Integer fx:value="4">
                            <Integer fx:value="5">
                            <Integer fx:value="6">
                            <Integer fx:value="7">
                            <Integer fx:value="8">
                            <Integer fx:value="9">
                            <Integer fx:value="10">
                            <Integer fx:value="11">
                            <Integer fx:value="12">
                        </FXCollections>
                    </items>
                </ComboBox>
            </children>
        <Button  fx:id="submitStudent" text="complete" onAction="#finishStudentAccount"/>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
