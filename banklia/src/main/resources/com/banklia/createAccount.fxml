<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.banklia.CreateAccountController">
    <children>
        <Label text="Create Account" />
        <TextField fx:id="nameField" promptText="enter your name"/>
        <TextField fx:id="passwordField" promptText="enter password"/>
        <ComboBox fx:id="clientType" promptText="choose your client type">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Individual"/>
                    <String fx:value="Student"/>
                    <String fx:value="Corporate"/>
                    <String fx:value="VIP"/>
                </FXCollections>
            </items>
        </ComboBox>
        <Button fx:id="secondaryButton" text="Confirm" onAction="#determineNext" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>